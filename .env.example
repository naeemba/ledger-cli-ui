# ============================================================================
# Required
# ============================================================================

# Server-side auth secret. Generate one with:
#   openssl rand -base64 32
# Must be at least 32 characters. Sessions will become invalid if this rotates.
BETTER_AUTH_SECRET=

# ============================================================================
# Deployment
# ============================================================================

# Deployment label — affects the app title, passkey rpName, and the displayed
# brand text. One of: local | test | stage | production.
# When unset: production builds default to "production", everything else to "local".
# Prefixed with NEXT_PUBLIC_ so it's available on the client too.
NEXT_PUBLIC_APP_ENV=local

# Port the Next.js server binds to. Defaults to 3000 when unset.
PORT=3002

# Canonical public URL of this deployment. Used for cookies, WebAuthn origin
# checks, redirect targets. Set to the actual public origin in stage/prod.
BETTER_AUTH_URL=http://localhost:3002

# ============================================================================
# Storage
# ============================================================================

# Root directory for persistent state — SQLite DB lives here, and (Phase 3+)
# encrypted user journals. In Docker/Coolify this is mounted as a volume.
DATA_DIR=./data

# Explicit SQLite path. Optional — defaults to ${DATA_DIR}/db.sqlite.
# Useful when DATA_DIR points at one place but you want the DB elsewhere.
# DATABASE_URL=

# ============================================================================
# Ledger
# ============================================================================

# Optional price-db file passed to `ledger --price-db`. Shared across all
# users. Per-user journals live under ${DATA_DIR}/journals/<userId>.ledger.
LEDGER_PRICE_DB=~/journals/price-db.ledger

# ============================================================================
# Display
# ============================================================================

# Fallback base currency for users who haven't set one in /settings.
# Active resolution order: session cookie > userSetting row > this value.
DEFAULT_CURRENCY=USD

# BCP 47 locale used by `Intl.DateTimeFormat`. Defaults to en-US.
DATE_LOCALE=en-US
